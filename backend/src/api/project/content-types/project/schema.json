{
  "kind":"collectionType","collectionName":"projects",
  "info":{"singularName":"project","pluralName":"projects","displayName":"Project","description":"Community projects with impact and funding data"},
  "options":{"draftAndPublish":true},
  "attributes":{
    "title":{"type":"string","required":true},"slug":{"type":"uid","targetField":"title","required":true},
    "shortDescription":{"type":"text","required":true},"description":{"type":"blocks"},
    "heroImage":{"type":"media","multiple":false,"allowedTypes":["images"]},"gallery":{"type":"media","multiple":true,"allowedTypes":["images","videos"]},
    "program":{"type":"relation","relation":"manyToOne","target":"api::program.program","inversedBy":"projects"},
    "location":{"type":"string"},"district":{"type":"string"},"country":{"type":"string","default":"Uganda"},"latitude":{"type":"decimal"},"longitude":{"type":"decimal"},
    "status":{"type":"enumeration","enum":["planned","active","on-hold","completed"],"default":"active"},"featured":{"type":"boolean","default":false},"homepageDisplay":{"type":"boolean","default":false},"displayOrder":{"type":"integer","default":0},
    "projectManager":{"type":"string"},"startDate":{"type":"date"},"expectedCompletion":{"type":"date"},"completionDate":{"type":"date"},
    "objectives":{"type":"blocks"},"activities":{"type":"blocks"},"challenges":{"type":"blocks"},"achievements":{"type":"blocks"},"expectedOutcomes":{"type":"blocks"},
    "beneficiaries":{"type":"integer","min":0},"fundingGoal":{"type":"decimal","min":0},"fundsRaised":{"type":"decimal","min":0,"default":0},"currency":{"type":"string","default":"UGX","maxLength":3},
    "volunteerOpportunities":{"type":"text"},"currentNeeds":{"type":"blocks"},"documents":{"type":"media","multiple":true,"allowedTypes":["files"]},
    "visibility":{"type":"enumeration","enum":["public","private"],"default":"public"},"seo":{"type":"component","component":"shared.seo","repeatable":false}
  }
}
