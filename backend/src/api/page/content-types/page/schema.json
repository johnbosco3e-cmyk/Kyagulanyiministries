{
  "kind": "collectionType",
  "collectionName": "pages",
  "info": { "singularName": "page", "pluralName": "pages", "displayName": "Page", "description": "General website pages" },
  "options": { "draftAndPublish": true },
  "attributes": {
    "title": { "type": "string", "required": true },
    "slug": { "type": "uid", "targetField": "title", "required": true },
    "summary": { "type": "text" },
    "content": { "type": "blocks" },
    "heroImage": { "type": "media", "multiple": false, "allowedTypes": ["images"] },
    "showInNavigation": { "type": "boolean", "default": false },
    "navigationOrder": { "type": "integer", "default": 0 },
    "seo": { "type": "component", "component": "shared.seo", "repeatable": false }
  }
}
