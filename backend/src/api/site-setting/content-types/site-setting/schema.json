{
  "kind": "singleType",
  "collectionName": "site_settings",
  "info": { "singularName": "site-setting", "pluralName": "site-settings", "displayName": "Site Setting", "description": "Organization identity and website contact details" },
  "options": { "draftAndPublish": true },
  "attributes": {
    "organizationName": { "type": "string", "required": true, "default": "Kyagulanyi Ministries" },
    "tagline": { "type": "string" },
    "mission": { "type": "text" },
    "vision": { "type": "text" },
    "logo": { "type": "media", "multiple": false, "allowedTypes": ["images"] },
    "favicon": { "type": "media", "multiple": false, "allowedTypes": ["images"] },
    "email": { "type": "email" },
    "phone": { "type": "string" },
    "address": { "type": "text" },
    "donationUrl": { "type": "string" },
    "facebookUrl": { "type": "string" },
    "instagramUrl": { "type": "string" },
    "youtubeUrl": { "type": "string" },
    "xUrl": { "type": "string" },
    "seo": { "type": "component", "component": "shared.seo", "repeatable": false }
  }
}
