{
  "kind": "collectionType",
  "collectionName": "campaigns",
  "info": { "singularName": "campaign", "pluralName": "campaigns", "displayName": "Campaign", "description": "Fundraising and awareness campaigns" },
  "options": { "draftAndPublish": true },
  "attributes": {
    "title": { "type": "string", "required": true },
    "slug": { "type": "uid", "targetField": "title", "required": true },
    "summary": { "type": "text", "required": true },
    "content": { "type": "blocks" },
    "goalAmount": { "type": "decimal", "min": 0 },
    "amountRaised": { "type": "decimal", "min": 0, "default": 0 },
    "currency": { "type": "string", "default": "UGX", "maxLength": 3 },
    "startDate": { "type": "date" },
    "endDate": { "type": "date" },
    "donationUrl": { "type": "string" },
    "featuredImage": { "type": "media", "multiple": false, "allowedTypes": ["images"] },
    "featured": { "type": "boolean", "default": false },
    "seo": { "type": "component", "component": "shared.seo", "repeatable": false }
  }
}
