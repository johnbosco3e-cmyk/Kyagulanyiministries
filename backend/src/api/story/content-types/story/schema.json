{
  "kind": "collectionType",
  "collectionName": "stories",
  "info": { "singularName": "story", "pluralName": "stories", "displayName": "Impact Story", "description": "News, testimonies, and impact stories" },
  "options": { "draftAndPublish": true },
  "attributes": {
    "title": { "type": "string", "required": true },
    "slug": { "type": "uid", "targetField": "title", "required": true },
    "excerpt": { "type": "text", "required": true },
    "content": { "type": "blocks", "required": true },
    "storyType": { "type": "enumeration", "enum": ["news", "testimony", "impact", "update"], "default": "impact" },
    "authorName": { "type": "string" },
    "featuredImage": { "type": "media", "multiple": false, "allowedTypes": ["images"] },
    "gallery": { "type": "media", "multiple": true, "allowedTypes": ["images", "videos"] },
    "featured": { "type": "boolean", "default": false },
    "program": { "type": "relation", "relation": "manyToOne", "target": "api::program.program", "inversedBy": "stories" },
    "seo": { "type": "component", "component": "shared.seo", "repeatable": false }
  }
}
